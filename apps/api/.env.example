# Copy to .env and fill in real values. NEVER commit .env.
NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/barbershop

# Redis connection string
REDIS_URL=redis://localhost:6379

# Session — SESSION_SECRET must be at least 32 characters
SESSION_SECRET=change-me-to-a-long-random-string-min-32
SESSION_MAX_AGE_MS=86400000

# JWT — JWT_SECRET must be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-string-min-32
JWT_EXPIRES_IN=8h

# PII protection — keyed HMAC for phone-derived redis/dedup keys. Min 32 chars.
PHONE_HMAC_SECRET=change-me-to-a-long-random-string-min-32

# CORS — wildcard subdomain pattern. Local dev: http://localhost:*
# Production (multi-shop): https://*.platform.dz  (each shop is slug.platform.dz)
ALLOWED_ORIGIN_PATTERN=https://*.platform.dz

# Cookie domain for cross-subdomain sessions. MUST be set in production so the owner
# session cookie set by api.platform.dz is sent on shop.platform.dz requests.
# Local dev: leave empty. Production: .platform.dz
COOKIE_DOMAIN=

# Exact number of reverse-proxy hops in front of the API (for correct client IP /
# rate limiting). Local (no proxy): 0. Behind one proxy/LB (Railway/Render): 1.
# NEVER set to 'true'. See app.ts.
TRUST_PROXY_HOPS=0
